{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "hostRules": [
    {
      "matchHost": "ghcr.io",
      "hostType": "docker",
      "username": "Quadrubo",
      "password": "{{ secrets.GHCR_TOKEN }}"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/modules/nixos/modules/containers/.*/default\\.nix$/"
      ],
      "matchStrings": [
        "default\\s*=\\s*\"(?<depName>.*?):(?<currentValue>[^:\"@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?\";\\s*#\\s*renovate:\\s*docker"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
